<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bank_statement_line_form_inherit_payment_method" model="ir.ui.view">
        <field name="name">account.bank.statement.line.form.inherit.payment.method</field>
        <field name="model">account.bank.statement.line</field>
        <field name="inherit_id" ref="account_accountant.view_bank_statement_line_form_bank_rec_widget"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="l10n_mx_edi_payment_method_id" options="{'no_create': 1, 'no_open': 1}"/>
            </xpath>
        </field>
    </record>
    
    <record id="view_bank_statement_line_search_inherit_payment_method" model="ir.ui.view">
        <field name="name">account.bank.statement.line.search.inherit.payment.method</field>
        <field name="model">account.bank.statement.line</field>
        <field name="inherit_id" ref="account_accountant.view_bank_statement_line_tree_bank_rec_widget"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='running_balance']" position="before">
                <field name="l10n_mx_edi_payment_method_id" optional="show" options="{'no_create': 1, 'no_open': 1}" />
            </xpath>
        </field>
    </record>



</odoo>
