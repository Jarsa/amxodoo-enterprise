#. module: l10n_mx_edi_cfdi_payment_followup
#: model:mail.template,body_html:l10n_mx_edi_cfdi_payment_followup.mail_template_cfdi_complement_request
msgid ""
"<div style=\"font-family: Arial, sans-serif; font-size: 14px; color: #333;\">\n"
"                <p>Dear <t t-out=\"object.partner_id.name or ''\"></t>,</p>\n"
"                <p>\n"
"                    We are requesting the CFDI Payment Complement (Complemento de Pago)\n"
"                    for the following payment:\n"
"                </p>\n"
"                <table style=\"border-collapse: collapse; width: 100%; margin-bottom: 16px;\">\n"
"                    <tr style=\"background-color: #f5f5f5;\">\n"
"                        <th style=\"border: 1px solid #ddd; padding: 8px; text-align: left;\">Field</th>\n"
"                        <th style=\"border: 1px solid #ddd; padding: 8px; text-align: left;\">Value</th>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td style=\"border: 1px solid #ddd; padding: 8px;\">Payment Reference</td>\n"
"                        <td style=\"border: 1px solid #ddd; padding: 8px;\">\n"
"                            <t t-out=\"object.name or ''\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td style=\"border: 1px solid #ddd; padding: 8px;\">Payment Date</td>\n"
"                        <td style=\"border: 1px solid #ddd; padding: 8px;\">\n"
"                            <t t-out=\"format_date(object.date) or ''\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td style=\"border: 1px solid #ddd; padding: 8px;\">Amount</td>\n"
"                        <td style=\"border: 1px solid #ddd; padding: 8px;\">\n"
"                            <t t-out=\"format_amount(object.amount_total, object.currency_id) or ''\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"                <p><strong>Related Invoices:</strong></p>\n"
"                <ul>\n"
"                    <t t-foreach=\"object._get_cfdi_reconciled_invoices()\" t-as=\"invoice\">\n"
"                        <li>\n"
"                            <t t-out=\"invoice.name or ''\"></t>\n"
"                            — <t t-out=\"format_amount(invoice.amount_total, invoice.currency_id) or ''\"></t>\n"
"                        </li>\n"
"                    </t>\n"
"                </ul>\n"
"                <p>\n"
"                    Please send the corresponding CFDI XML file at your earliest convenience.\n"
"                </p>\n"
"                <p>\n"
"                    Thank you,<br>\n"
"                    <t t-out=\"object.company_id.name or ''\"></t>\n"
"                </p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"font-family: Arial, sans-serif; font-size: 14px; color: #333;\">\n"
"                <p>Estimado(a) <t t-out=\"object.partner_id.name or ''\"></t>,</p>\n"
"                <p>\n"
"                    Le solicitamos el Complemento de Pago CFDI (Complemento de Pago)\n"
"                    para el siguiente pago:\n"
"                </p>\n"
"                <table style=\"border-collapse: collapse; width: 100%; margin-bottom: 16px;\">\n"
"                    <tr style=\"background-color: #f5f5f5;\">\n"
"                        <th style=\"border: 1px solid #ddd; padding: 8px; text-align: left;\">Campo</th>\n"
"                        <th style=\"border: 1px solid #ddd; padding: 8px; text-align: left;\">Valor</th>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td style=\"border: 1px solid #ddd; padding: 8px;\">Referencia del Pago</td>\n"
"                        <td style=\"border: 1px solid #ddd; padding: 8px;\">\n"
"                            <t t-out=\"object.name or ''\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td style=\"border: 1px solid #ddd; padding: 8px;\">Fecha de Pago</td>\n"
"                        <td style=\"border: 1px solid #ddd; padding: 8px;\">\n"
"                            <t t-out=\"format_date(object.date) or ''\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td style=\"border: 1px solid #ddd; padding: 8px;\">Importe</td>\n"
"                        <td style=\"border: 1px solid #ddd; padding: 8px;\">\n"
"                            <t t-out=\"format_amount(object.amount_total, object.currency_id) or ''\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"                <p><strong>Facturas Relacionadas:</strong></p>\n"
"                <ul>\n"
"                    <t t-foreach=\"object._get_cfdi_reconciled_invoices()\" t-as=\"invoice\">\n"
"                        <li>\n"
"                            <t t-out=\"invoice.name or ''\"></t>\n"
"                            — <t t-out=\"format_amount(invoice.amount_total, invoice.currency_id) or ''\"></t>\n"
"                        </li>\n"
"                    </t>\n"
"                </ul>\n"
"                <p>\n"
"                    Por favor, envíe el archivo XML del CFDI correspondiente a la brevedad posible.\n"
"                </p>\n"
"                <p>\n"
"                    Gracias,<br>\n"
"                    <t t-out=\"object.company_id.name or ''\"></t>\n"
"                </p>\n"
"            </div>\n"
"        "

