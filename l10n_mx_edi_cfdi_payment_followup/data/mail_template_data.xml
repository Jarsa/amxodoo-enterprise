<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="mail_template_cfdi_complement_request" model="mail.template">
        <field name="name">CFDI Payment Complement Request</field>
        <field name="model_id" ref="account.model_account_move" />
        <field name="subject">Payment Complement Request — {{ object.name }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="lang">{{ object.partner_id.lang }}</field>
        <field name="auto_delete" eval="False" />
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; font-size: 14px; color: #333;">
                <p>Dear <t t-out="object.partner_id.name or ''" />,</p>
                <p>
                    We are requesting the CFDI Payment Complement (Complemento de Pago)
                    for the following payment:
                </p>
                <table
                    style="border-collapse: collapse; width: 100%; margin-bottom: 16px;"
                >
                    <tr style="background-color: #f5f5f5;">
                        <th
                            style="border: 1px solid #ddd; padding: 8px; text-align: left;"
                        >Field</th>
                        <th
                            style="border: 1px solid #ddd; padding: 8px; text-align: left;"
                        >Value</th>
                    </tr>
                    <tr>
                        <td
                            style="border: 1px solid #ddd; padding: 8px;"
                        >Payment Reference</td>
                        <td style="border: 1px solid #ddd; padding: 8px;">
                            <t t-out="object.name or ''" />
                        </td>
                    </tr>
                    <tr>
                        <td
                            style="border: 1px solid #ddd; padding: 8px;"
                        >Payment Date</td>
                        <td style="border: 1px solid #ddd; padding: 8px;">
                            <t t-out="format_date(object.date) or ''" />
                        </td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid #ddd; padding: 8px;">Amount</td>
                        <td style="border: 1px solid #ddd; padding: 8px;">
                            <t
                                t-out="format_amount(object.amount_total, object.currency_id) or ''"
                            />
                        </td>
                    </tr>
                </table>
                <p><strong>Related Invoices:</strong></p>
                <table
                    style="border-collapse: collapse; width: 100%; margin-bottom: 16px;"
                >
                    <tr style="background-color: #f5f5f5;">
                        <th
                            style="border: 1px solid #ddd; padding: 8px; text-align: left;"
                        >Invoice</th>
                        <th
                            style="border: 1px solid #ddd; padding: 8px; text-align: left;"
                        >Vendor Reference</th>
                        <th
                            style="border: 1px solid #ddd; padding: 8px; text-align: left;"
                        >Applied Amount</th>
                    </tr>
                    <t
                        t-foreach="object._get_cfdi_reconciled_invoice_details()"
                        t-as="detail"
                    >
                        <tr>
                            <td style="border: 1px solid #ddd; padding: 8px;">
                                <t t-out="detail['invoice'].name or ''" />
                            </td>
                            <td style="border: 1px solid #ddd; padding: 8px;">
                                <t t-out="detail['invoice'].ref or ''" />
                            </td>
                            <td style="border: 1px solid #ddd; padding: 8px;">
                                <t
                                    t-out="format_amount(detail['amount'], detail['invoice'].currency_id) or ''"
                                />
                            </td>
                        </tr>
                    </t>
                </table>
                <p>
                    Please send the corresponding CFDI XML file at your earliest convenience.
                </p>
                <p>
                    Thank you,<br />
                    <t t-out="object.company_id.name or ''" />
                </p>
            </div>
        </field>
    </record>
</odoo>
