<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Bank reconciliation list view: add CFDI state columns and action button -->
    <record id="view_bank_statement_line_tree_cfdi_followup" model="ir.ui.view">
        <field name="name">
            account.bank.statement.line.tree.cfdi.payment.followup
        </field>
        <field name="model">account.bank.statement.line</field>
        <field
            name="inherit_id"
            ref="account_accountant.view_bank_statement_line_tree_bank_rec_widget"
        />
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <header>
                    <button
                        name="action_request_cfdi_complement_mass"
                        type="object"
                        string="Request Complements"
                    />
                </header>
            </xpath>
            <xpath expr="//field[@name='id']" position="before">
                <field
                    name="l10n_mx_edi_cfdi_is_supplier_payment"
                    column_invisible="1"
                />
                <field
                    name="l10n_mx_edi_cfdi_payment_state"
                    optional="show"
                    widget="badge"
                    decoration-success="l10n_mx_edi_cfdi_payment_state == 'validated'"
                    decoration-warning="l10n_mx_edi_cfdi_payment_state == 'pending'"
                    decoration-info="l10n_mx_edi_cfdi_payment_state == 'requested'"
                    decoration-danger="l10n_mx_edi_cfdi_payment_state == 'error'"
                />
                <field
                    name="l10n_mx_edi_cfdi_payment_last_followup_date"
                    optional="hide"
                />
                <field
                    name="l10n_mx_edi_cfdi_payment_receipt_filename"
                    column_invisible="1"
                />
                <field
                    name="l10n_mx_edi_cfdi_payment_receipt"
                    widget="binary"
                    filename="l10n_mx_edi_cfdi_payment_receipt_filename"
                    invisible="not l10n_mx_edi_cfdi_is_supplier_payment or l10n_mx_edi_cfdi_payment_state == 'not_required'"
                    optional="show"
                />
                <button
                    name="action_open_receipt_wizard"
                    type="object"
                    icon="fa-upload"
                    title="Upload Receipt"
                    invisible="not l10n_mx_edi_cfdi_is_supplier_payment or l10n_mx_edi_cfdi_payment_state == 'not_required'"
                    class="btn btn-secondary"
                />
            </xpath>
        </field>
    </record>

    <!-- Bank reconciliation kanban view: show CFDI state badge -->
    <record id="view_bank_statement_line_kanban_cfdi_followup" model="ir.ui.view">
        <field name="name">
            account.bank.statement.line.kanban.cfdi.payment.followup
        </field>
        <field name="model">account.bank.statement.line</field>
        <field
            name="inherit_id"
            ref="account_accountant.view_bank_statement_line_kanban_bank_rec_widget"
        />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='to_check']" position="after">
                <field name="l10n_mx_edi_cfdi_is_supplier_payment" invisible="1" />
                <field name="l10n_mx_edi_cfdi_payment_state" />
                <field name="l10n_mx_edi_cfdi_payment_receipt_filename" invisible="1" />
            </xpath>
            <xpath expr="//div[@id='row2_col2']/div" position="inside">
                <span
                    t-if="record.l10n_mx_edi_cfdi_payment_state.raw_value == 'pending'"
                    class="badge text-bg-warning fw-normal"
                    title="CFDI Pending"
                >CFDI Pending</span>
                <span
                    t-if="record.l10n_mx_edi_cfdi_payment_state.raw_value == 'requested'"
                    class="badge text-bg-info fw-normal"
                    title="CFDI Requested"
                >CFDI Requested</span>
                <span
                    t-if="record.l10n_mx_edi_cfdi_payment_state.raw_value == 'validated'"
                    class="badge text-bg-success fw-normal"
                    title="CFDI Validated"
                >CFDI <i class="fa fa-check" /></span>
                <span
                    t-if="record.l10n_mx_edi_cfdi_payment_state.raw_value == 'error'"
                    class="badge text-bg-danger fw-normal"
                    title="CFDI Error"
                >CFDI Error</span>
                <a
                    t-if="record.l10n_mx_edi_cfdi_payment_receipt_filename.raw_value"
                    t-att-href="'/web/content/account.bank.statement.line/' + record.id.raw_value + '/l10n_mx_edi_cfdi_payment_receipt?download=true'"
                    class="btn btn-secondary ms-1 me-1"
                    title="Download Receipt"
                >
                    <i class="fa fa-download" />
                </a>
                <button
                    name="action_open_receipt_wizard"
                    type="object"
                    icon="fa-upload"
                    title="Upload/View Receipt"
                    invisible="not l10n_mx_edi_cfdi_is_supplier_payment or l10n_mx_edi_cfdi_payment_state == 'not_required'"
                    class="btn btn-secondary"
                />
            </xpath>
        </field>
    </record>

    <!-- Search view: CFDI state filters for bank statement lines -->
    <record id="view_bank_statement_line_search_cfdi_followup" model="ir.ui.view">
        <field name="name">
            account.bank.statement.line.search.cfdi.payment.followup
        </field>
        <field name="model">account.bank.statement.line</field>
        <field
            name="inherit_id"
            ref="account_accountant.view_bank_statement_line_search_bank_rec_widget"
        />
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter
                    name="cfdi_not_required"
                    string="CFDI Not Required"
                    domain="[('l10n_mx_edi_cfdi_payment_state', '=', 'not_required')]"
                />
                <filter
                    name="cfdi_pending"
                    string="CFDI Pending"
                    domain="[('l10n_mx_edi_cfdi_payment_state', '=', 'pending')]"
                />
                <filter
                    name="cfdi_requested"
                    string="CFDI Requested"
                    domain="[('l10n_mx_edi_cfdi_payment_state', '=', 'requested')]"
                />
                <filter
                    name="cfdi_error"
                    string="CFDI Error"
                    domain="[('l10n_mx_edi_cfdi_payment_state', '=', 'error')]"
                />
                <filter
                    name="cfdi_validated"
                    string="CFDI Validated"
                    domain="[('l10n_mx_edi_cfdi_payment_state', '=', 'validated')]"
                />
                <separator />
                <filter
                    name="group_cfdi_state"
                    string="CFDI State"
                    context="{'group_by': 'l10n_mx_edi_cfdi_payment_state'}"
                />
            </xpath>
        </field>
    </record>

    <!-- Form view: Popup to upload the CFDI receipt -->
    <record id="view_bank_statement_line_form_receipt_upload" model="ir.ui.view">
        <field name="name">account.bank.statement.line.receipt.upload</field>
        <field name="model">account.bank.statement.line</field>
        <field name="arch" type="xml">
            <form string="Upload Receipt">
                <group>
                    <field
                        name="l10n_mx_edi_cfdi_payment_receipt_filename"
                        invisible="1"
                    />
                    <field
                        name="l10n_mx_edi_cfdi_payment_receipt"
                        widget="binary"
                        filename="l10n_mx_edi_cfdi_payment_receipt_filename"
                    />
                </group>
                <footer>
                    <button string="Save" special="save" class="btn-primary" />
                    <button string="Cancel" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>
</odoo>
