<data noupdate="1">
    <record id="mail_template_data_payment_receipt" model="mail.template">
            <field name="name">Payment: Payment Receipt</field>
            <field name="model_id" ref="l10n_mx_edi.model_l10n_mx_edi_document"/>
            <field name="subject">{{ object.move_id.company_id.name }} Payment Receipt (Ref {{ object.move_id.name or 'n/a' }})</field>
            <field name="partner_to">{{ object.move_id.partner_id.id }}</field>
            <field name="description">Sent manually to customer when clicking on 'Send receipt by email' in payment action</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Dear <t t-out="object.move_id.partner_id.name or ''">Azure Interior</t><br/><br/>
        Thank you for your payment.
        Here is your payment receipt <span style="font-weight:bold;" t-out="(object.move_id.name or '').replace('/','-') or ''">BNK1-2021-05-0002</span> amounting
        to <span style="font-weight:bold;" t-out="format_amount(object.move_id.statement_line_id.amount or object.move_id.payment_id.amount, object.move_id.currency_id) or ''">$ 10.00</span> from <t t-out="object.move_id.company_id.name or ''">YourCompany</t>.
        <br/><br/>
        Do not hesitate to contact us if you have any questions.
        <br/><br/>
        Best regards,
        <t t-if="not is_html_empty(user.signature)">
            <br/><br/>
            <t t-out="user.signature or ''">--<br/>Mitchell Admin</t>
        </t>
    </p>
</div>
</field>
            <field name="report_template_ids" eval="[(4, ref('l10n_mx_edi_account_move_payment_report.report_payment_receipt_invoice'))]"/>
            <field name="lang">{{ object.move_id.partner_id.lang }}</field>
            <field name="auto_delete" eval="True"/>
        </record>
</data>