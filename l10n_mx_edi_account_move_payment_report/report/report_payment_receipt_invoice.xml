<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="report_payment_receipt_invoice" model="ir.actions.report">
            <field name="name">Payment Receipt</field>
            <field name="model">l10n_mx_edi.document</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">l10n_mx_edi_account_move_payment_report.report_payment_receipt_invoice_template</field>
            <field name="print_report_name">'Payment Receipt - %s' % (object.move_id.name)</field>
        </record>

        <template id="report_payment_receipt_invoice_template">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <main>
                        <t t-set="lang" t-value="o.move_id.partner_id.lang or o.move_id.company_id.partner_id.lang"/>
                        <t t-set="cfdi_info" t-value="o._l10n_mx_edi_get_extra_payment_report_values()"/>
                        <t t-set="o" t-value="o.with_context(lang=lang)"/>
                        <div class="mb-4 mt-3">
                            <div class="page">
                                <h3><strong id="payment_title">Payment Receipt: <span t-esc="o.move_id.name"></span></strong></h3>
                                <div name="date" class="row">
                                    <div class="col-6">
                                        <t t-set="d" t-value="str(o.datetime).split(' ')[0].split('-')"/>
                                        <span>Payment Date: <t t-esc="d[1]"/>/<t t-esc="d[2]"/>/<t t-esc="d[0]"/></span>
                                    </div>
                                </div>

                                <div t-if="cfdi_info and o.move_id.company_id.vat != cfdi_info['supplier_rfc']" class="col-6">
                                    <span>XML VAT: </span>
                                    <span t-out="o.move_id.company_id.vat"/>
                                    <span t-out="cfdi_info['supplier_rfc']"/>
                                </div>
                                <div t-if="cfdi_info and o.move_id.l10n_mx_edi_payment_method_id" class="col-6">
                                    <strong>Payment Way:</strong>
                                    <span t-out="'%s - %s' % (o.move_id.l10n_mx_edi_payment_method_id.code, o.move_id.l10n_mx_edi_payment_method_id.name)"/>
                                </div>

                                <div class="row">
                                    <div class="col-6" t-if="o.move_id.partner_id">
                                        <t>
                                            Customer:                                        
                                        </t><span t-field="o.move_id.partner_id" data-oe-demo="Marc Demo"/>
                                    </div>

                                    <div name="payment_method"
                                        t-if="o.move_id.l10n_mx_edi_payment_method_id"
                                        class="col-6">
                                        Payment Method: <span t-field="o.move_id.l10n_mx_edi_payment_method_id.name">Credit card</span>
                                    </div>

                                </div>
                                <div class="row">
                                    <div class="col-6" t-if="o.move_id.amount_total">
                                        Payment Amount: <span t-field="o.move_id.amount_total" t-options="{'widget': 'monetary', 'display_currency': o.move_id.currency_id}">50 USD</span>
                                    </div>
                                    <div class="col-6" t-if="o.move_id.ref">
                                        Memo: <span t-field="o.move_id.ref">Sample Memo</span>
                                    </div>
                                </div>

                                <div class="row" t-if="cfdi_info['sello_sat'] and cfdi_info['stamp_date'] and o.move_id.partner_id.l10n_mx_edi_fiscal_regime">
                                    <div class="col-6">
                                        Fiscal Regime: (<span t-out="o.move_id.partner_id.l10n_mx_edi_fiscal_regime"/>) <span t-field="o.move_id.partner_id.l10n_mx_edi_fiscal_regime"/>
                                    </div>
                                </div>
                            </div>

                            <t t-if="cfdi_info and len(cfdi_info['cfdi_node'])">
                                <t t-set="payment_info" t-value="cfdi_info.get('payment_info')"/>
                                <table class="table table-sm" t-if="payment_info">
                                    <thead>
                                        <tr>
                                            <th t-if="payment_info['from_account_vat']"><t t-out="o.move_id.company_id.account_fiscal_country_id.vat_label or 'VAT'"/><span class="ps-1">Emitter Acc. Ord.</span></th>
                                            <th t-if="payment_info['from_account_name']">Bank Name Acc. Ord.</th>
                                            <th t-if="payment_info['from_account_number']">Account Ord.</th>
                                            <th t-if="payment_info['to_account_vat']"><t t-out="o.move_id.company_id.account_fiscal_country_id.vat_label or 'VAT'"/><span class="ps-1">Emitter Acc. Ben.</span></th>
                                            <th t-if="payment_info['to_account_number']">Account Ben.</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td t-if="payment_info['from_account_vat']">
                                                <span t-out="payment_info['from_account_vat']"/>
                                            </td>
                                            <td t-if="payment_info['from_account_name']">
                                                <span t-out="payment_info['from_account_name']"/>
                                            </td>
                                            <td t-if="payment_info['from_account_number']">
                                                <span t-out="payment_info['from_account_number']"/>
                                            </td>
                                            <td t-if="payment_info['to_account_vat']">
                                                <span t-out="payment_info['to_account_vat']"/>
                                            </td>
                                            <td t-if="payment_info['to_account_number']">
                                                <span t-out="payment_info['to_account_number']"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </t>

                            
                            <t t-if="cfdi_info">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Invoice</th>
                                            <th>UUID</th>
                                            <th class="text-end">Partiality</th>
                                            <th class="text-end">Previous balance</th>
                                            <th class="text-end">Amount Paid</th>
                                            <th class="text-end">Balance</th>
                                            <th>Currency</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="cfdi_info['invoices']" t-as="inv_values">
                                            <td><span t-out="inv_values['invoice'].name"/></td>
                                            <td><span t-out="inv_values['uuid']"/></td>
                                            <td class="text-end"><span t-out="inv_values['partiality']"/></td>
                                            <td class="text-end">
                                                <span t-out="inv_values['previous_balance']"
                                                    t-options="{'widget': 'monetary', 'display_currency': inv_values['invoice'].currency_id}"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-out="inv_values['amount_paid']"
                                                    t-options="{'widget': 'monetary', 'display_currency': inv_values['invoice'].currency_id}"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-out="inv_values['balance']"
                                                    t-options="{'widget': 'monetary', 'display_currency': inv_values['invoice'].currency_id}"/>
                                            </td>
                                            <td><span t-out="inv_values['currency']"/></td>
                                        </tr>
                                    </tbody>
                                </table>

                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Invoice Date</th>
                                            <th>Invoice Number</th>
                                            <th class="text-end">Original Amount</th>
                                            <th class="text-end">Amount Paid</th>
                                            <th class="text-end">Balance</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="cfdi_info['invoices']" t-as="inv_values">
                                            <t t-set="invoice" t-value="inv_values['invoice']"/>
                                            <td><span t-field="invoice.invoice_date"/></td>
                                            <td><span t-field="invoice.name"/></td>
                                            <td class="text-end"><span t-field="invoice.amount_total"/></td>
                                            <td class="text-end">
                                                <span t-out="invoice.amount_total - invoice.amount_residual"
                                                    t-options="{'widget': 'monetary', 'display_currency': invoice.currency_id}"/>
                                            </td>
                                            <td class="text-end"><span t-field="invoice.amount_residual"/></td>
                                        </tr>
                                    </tbody>
                                </table>

                                <div class="row" id='complement'>
                                    <div class="barcode col-3">
                                        <img alt="Barcode" t-att-src="cfdi_info['barcode_src']"/>
                                    </div>
                                    <div class="complement-details col-9">
                                        <div class="digital-stamp">
                                            <span>Digital stamp of the emitter</span>
                                        </div>
                                        <div class="digital-stamp-content">
                                            <span t-out="cfdi_info['sello']"/>
                                        </div>
                                        <div class="digital-stamp">
                                            <span>Digital stamp SAT</span>
                                        </div>
                                        <div class="digital-stamp-content">
                                            <span t-out="cfdi_info['sello_sat']"/>
                                        </div>
                                        <div class="digital-stamp">
                                            <span>Original chain complement of digital certification SAT</span>
                                        </div>
                                        <div class="digital-stamp-content">
                                            <span class="nowrap" t-out="cfdi_info['cadena']"/>
                                        </div>
                                        <div class="digital-stamp">
                                            <span>Extra Info</span>
                                        </div>
                                        <div class="digital-stamp-content">
                                            <span>Emitter certificate:</span> <span t-out="cfdi_info['certificate_number']"/>
                                            <span> | SAT Certificate:</span> <span t-out="cfdi_info['certificate_sat_number']"/>
                                            <span> | Expedition place:</span> <span t-out="cfdi_info['expedition']"/>
                                            <span> | Fiscal Regime:</span><span t-out="cfdi_info['fiscal_regime']"/>
                                            <span> | Emission Date:</span> <span t-out="cfdi_info['emission_date_str']"/>
                                            <span> | Certification Date:</span> <span t-out="cfdi_info['stamp_date']"/>
                                            <span> | Fiscal Folio:</span> <span t-out="cfdi_info['uuid']"/>
                                        </div>
                                        <div class="digital-stamp-content text-center">
                                            <strong>This document is a printed representation of a CFDI</strong>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div> 
                    </main>
                </t>
            </t>
        </template>

    </data>
</odoo>
